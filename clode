#!/usr/bin/env python3
"""
clode — tile your Claude Code sessions in iTerm2 right now.

Run this in iTerm2:
    clode          # tile current sessions + start background watcher
    clode tile     # tile only (no daemon start)
    clode stop     # stop the background watcher
    clode status   # show current sessions without changing anything
"""

import json
import os
import subprocess
import sys

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
PANE_MANAGER = os.path.join(SCRIPT_DIR, "pane_manager.py")
DAEMON_SCRIPT = os.path.join(SCRIPT_DIR, "clode_daemon.py")


# ---------------------------------------------------------------------------
# Session discovery (shared with daemon)
# ---------------------------------------------------------------------------

def get_sessions_via_claude_cli():
    try:
        result = subprocess.run(
            ["claude", "session", "list", "--json"],
            capture_output=True, text=True, timeout=5,
        )
        if result.returncode == 0 and result.stdout.strip():
            data = json.loads(result.stdout)
            if isinstance(data, list):
                return data
            if isinstance(data, dict) and "sessions" in data:
                return data["sessions"]
    except (subprocess.TimeoutExpired, FileNotFoundError, json.JSONDecodeError):
        pass
    return None


def get_sessions_via_pgrep():
    try:
        result = subprocess.run(
            ["pgrep", "-fl", "claude"],
            capture_output=True, text=True, timeout=5,
        )
        sessions = []
        seen = set()
        for line in result.stdout.splitlines():
            parts = line.split(None, 1)
            if not parts:
                continue
            pid_str, cmdline = parts[0], (parts[1] if len(parts) > 1 else "")
            if any(x in cmdline for x in ("clode", "pane_manager")):
                continue
            if "claude" not in cmdline.lower():
                continue
            try:
                pid = int(pid_str)
            except ValueError:
                continue
            if pid in seen:
                continue
            seen.add(pid)
            cwd = _get_cwd(pid)
            sessions.append({"id": str(pid), "pid": pid, "cwd": cwd, "_fallback": True})
        return sessions
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return []


def _get_cwd(pid):
    try:
        r = subprocess.run(
            ["lsof", "-p", str(pid), "-a", "-d", "cwd", "-Fn"],
            capture_output=True, text=True, timeout=5,
        )
        for line in r.stdout.splitlines():
            if line.startswith("n"):
                return line[1:]
    except (subprocess.TimeoutExpired, FileNotFoundError):
        pass
    return ""


def get_sessions():
    sessions = get_sessions_via_claude_cli()
    if sessions is None:
        sessions = get_sessions_via_pgrep()
    return sessions


# ---------------------------------------------------------------------------
# Daemon control
# ---------------------------------------------------------------------------

def daemon_running():
    try:
        result = subprocess.run(
            ["pgrep", "-f", "clode_daemon.py"],
            capture_output=True, text=True,
        )
        return result.returncode == 0
    except FileNotFoundError:
        return False


def start_daemon():
    subprocess.Popen(
        [sys.executable, DAEMON_SCRIPT],
        start_new_session=True,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    print("Watcher started (clode_daemon.py). Logs → ~/.claude-panes.log")


def stop_daemon():
    result = subprocess.run(["pkill", "-f", "clode_daemon.py"], capture_output=True)
    if result.returncode == 0:
        print("Watcher stopped.")
    else:
        print("Watcher was not running.")


# ---------------------------------------------------------------------------
# Tile / status
# ---------------------------------------------------------------------------

def tile(sessions):
    if not sessions:
        print("No active Claude Code sessions found.")
        return
    print(f"Found {len(sessions)} session(s). Tiling…")
    subprocess.run([sys.executable, PANE_MANAGER, "tile", json.dumps(sessions)])


def show_status(sessions):
    if not sessions:
        print("No active Claude Code sessions.")
        return
    print(f"{len(sessions)} active Claude Code session(s):")
    for i, s in enumerate(sessions, 1):
        sid = s.get("id") or s.get("pid", "?")
        cwd = s.get("cwd", "")
        fallback = " (pid-based)" if s.get("_fallback") else ""
        print(f"  {i}. id={sid}{fallback}" + (f"  cwd={cwd}" if cwd else ""))


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    subcommand = sys.argv[1] if len(sys.argv) > 1 else "default"

    if subcommand == "stop":
        stop_daemon()
        return

    sessions = get_sessions()

    if subcommand == "status":
        show_status(sessions)
        return

    # default or "tile": tile now, then ensure daemon is running
    tile(sessions)

    if subcommand == "default":
        if daemon_running():
            print("Watcher already running.")
        else:
            start_daemon()


if __name__ == "__main__":
    main()
